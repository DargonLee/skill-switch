<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Critical: Allow JIT for WebKit/WebView to function -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow executable memory for WebKit -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation (needed for plugins) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow dyld environment variables -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Network access -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Disable App Sandbox entirely for non-App Store distribution -->
    <!-- Without sandbox entitlements, the app runs without sandbox restrictions -->
    <!-- This is required for accessing ~/.claude, ~/.codex, etc. -->
</dict>
</plist>